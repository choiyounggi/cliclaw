{
  "name": "@younggichoi/cliclaw",
  "version": "0.6.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Telegram bridge for local coding CLIs (Claude Code, Codex, Pi) with per-chat sessions, confirm gate, streaming, and image attachments.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/choiyounggi/cliclaw.git"
  },
  "homepage": "https://github.com/choiyounggi/cliclaw#readme",
  "bugs": "https://github.com/choiyounggi/cliclaw/issues",
  "keywords": [
    "telegram",
    "claude",
    "claude-code",
    "codex",
    "pi",
    "bot",
    "agent",
    "ai"
  ],
  "bin": {
    "cliclaw": "bin/cliclaw"
  },
  "files": [
    "bin/",
    "lib/",
    "samples/",
    "bot.ts",
    "cli.ts",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "start": "bun run cli.ts start",
    "dev": "bun run --hot bot.ts",
    "test": "bun --bun x vitest run",
    "test:watch": "bun --bun x vitest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.7.0",
    "vitest": "^2.1.0"
  }
}
